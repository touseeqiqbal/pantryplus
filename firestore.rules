rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ============================================================================
    // HELPER FUNCTIONS
    // ============================================================================
    
    // Check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // --- INPUT VALIDATION ---

    // Inventory write must include the core required fields with valid types.
    function isValidInventory(data) {
      return data.name is string && data.name.size() > 0 &&
        data.category is string &&
        data.quantity is number && data.quantity >= 0 &&
        data.unit is string;
    }
    
    // --- HOUSEHOLD HELPERS ---
    
    function isHouseholdMember(householdId) {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/households/$(householdId)) &&
        get(/databases/$(database)/documents/households/$(householdId))
          .data.memberIds.hasAny([request.auth.uid]);
    }
    
    function isHouseholdAdmin(householdId) {
      return isHouseholdOwner(householdId);
    }
    
    function isHouseholdOwner(householdId) {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/households/$(householdId)) &&
        get(/databases/$(database)/documents/households/$(householdId))
          .data.createdBy == request.auth.uid;
    }
    
    // --- BUSINESS HELPERS ---
    
    function isBusinessOwner(businessId) {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/businesses/$(businessId)) &&
        get(/databases/$(database)/documents/businesses/$(businessId))
          .data.ownerId == request.auth.uid;
    }

    function isBusinessStaff(businessId) {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/staff/$(businessId + "_" + request.auth.uid));
    }

    function isBusinessMember(businessId) {
      return isBusinessOwner(businessId) || isBusinessStaff(businessId);
    }
    
    // ============================================================================
    // HOUSEHOLDS & BUSINESSES (Top-level Contexts)
    // ============================================================================
    
    match /households/{householdId} {
      allow read: if isAuthenticated() && isHouseholdMember(householdId);
      allow create: if isAuthenticated() &&
        request.resource.data.createdBy == request.auth.uid &&
        request.resource.data.memberIds.hasAny([request.auth.uid]);
      allow update: if isAuthenticated() && isHouseholdAdmin(householdId);
      allow delete: if isAuthenticated() && isHouseholdOwner(householdId);
    }

    match /businesses/{businessId} {
      allow read: if isAuthenticated() && isBusinessMember(businessId);
      allow create: if isAuthenticated() && 
        request.resource.data.ownerId == request.auth.uid;
      allow update: if isAuthenticated() && isBusinessOwner(businessId);
      allow delete: if isAuthenticated() && isBusinessOwner(businessId);
    }

    match /branches/{branchId} {
      allow read: if isAuthenticated() && isBusinessMember(resource.data.businessId);
      allow create: if isAuthenticated() && isBusinessOwner(request.resource.data.businessId);
      allow update, delete: if isAuthenticated() && isBusinessOwner(resource.data.businessId);
    }

    match /staff/{staffId} {
      // staffId is "businessId_uid"
      allow read: if isAuthenticated() && 
        (request.auth.uid == data.userId || isBusinessOwner(data.businessId));
      allow create, update, delete: if isAuthenticated() && isBusinessOwner(request.resource.data.businessId);
    }
    
    // ============================================================================
    // INVENTORY, SHOPPING, RECIPES (Shared logic)
    // ============================================================================
    
    match /inventory/{itemId} {
      allow read: if isAuthenticated() && (
        (resource.data.keys().hasAll(['householdId']) && isHouseholdMember(resource.data.householdId)) ||
        (resource.data.keys().hasAll(['businessId']) && isBusinessMember(resource.data.businessId))
      );
      
      allow create: if isAuthenticated() && isValidInventory(request.resource.data) && (
        (request.resource.data.keys().hasAll(['householdId']) && isHouseholdMember(request.resource.data.householdId)) ||
        (request.resource.data.keys().hasAll(['businessId']) && isBusinessMember(request.resource.data.businessId))
      );

      allow update: if isAuthenticated() && isValidInventory(request.resource.data) && (
        (resource.data.keys().hasAll(['householdId']) && isHouseholdMember(resource.data.householdId)) ||
        (resource.data.keys().hasAll(['businessId']) && isBusinessMember(resource.data.businessId))
      );

      allow delete: if isAuthenticated() && (
        (resource.data.keys().hasAll(['householdId']) && isHouseholdMember(resource.data.householdId)) ||
        (resource.data.keys().hasAll(['businessId']) && isBusinessMember(resource.data.businessId))
      );
    }

    match /shopping/{itemId} {
      allow read, update, delete: if isAuthenticated() && (
        (resource.data.keys().hasAll(['householdId']) && isHouseholdMember(resource.data.householdId)) ||
        (resource.data.keys().hasAll(['businessId']) && isBusinessMember(resource.data.businessId))
      );
      allow create: if isAuthenticated() && (
        (request.resource.data.keys().hasAll(['householdId']) && isHouseholdMember(request.resource.data.householdId)) ||
        (request.resource.data.keys().hasAll(['businessId']) && isBusinessMember(request.resource.data.businessId))
      );
    }

    match /recipes/{recipeId} {
      allow read, update, delete: if isAuthenticated() && (
        (resource.data.keys().hasAll(['householdId']) && isHouseholdMember(resource.data.householdId)) ||
        (resource.data.keys().hasAll(['businessId']) && isBusinessMember(resource.data.businessId))
      );
      allow create: if isAuthenticated() && (
        (request.resource.data.keys().hasAll(['householdId']) && isHouseholdMember(request.resource.data.householdId)) ||
        (request.resource.data.keys().hasAll(['businessId']) && isBusinessMember(request.resource.data.businessId))
      );
    }
    
    // ============================================================================
    // BUSINESS OPERATIONS (Menu, Mappings, Yield)
    // ============================================================================
    
    match /menuItems/{menuId} {
      allow read: if isAuthenticated() && isBusinessMember(resource.data.businessId);
      allow write: if isAuthenticated() && isBusinessMember(request.resource.data.businessId);
    }

    match /ingredientMappings/{mappingId} {
      allow read: if isAuthenticated() && isBusinessMember(resource.data.businessId);
      allow write: if isAuthenticated() && isBusinessMember(request.resource.data.businessId);
    }

    match /yieldLogs/{logId} {
      allow read: if isAuthenticated() && isBusinessMember(resource.data.businessId);
      allow create: if isAuthenticated() && isBusinessMember(request.resource.data.businessId);
      allow update, delete: if false; // Logs are immutable
    }

    // ============================================================================
    // PERSONAL HOUSEHOLD FEATURES
    // ============================================================================
    
    match /invitations/{invitationId} {
      allow read: if isAuthenticated() &&
        (resource.data.invitedEmail == request.auth.token.email ||
         isHouseholdMember(resource.data.householdId));
      allow create: if isAuthenticated() && isHouseholdAdmin(request.resource.data.householdId);
      allow update: if isAuthenticated() && resource.data.invitedEmail == request.auth.token.email;
      allow delete: if isAuthenticated() && isHouseholdAdmin(resource.data.householdId);
    }
    
    match /meals/{mealId} {
      allow read, update, delete: if isAuthenticated() && isHouseholdMember(resource.data.householdId);
      allow create: if isAuthenticated() && isHouseholdMember(request.resource.data.householdId);
    }

    match /tasks/{taskId} {
      allow read, update, delete: if isAuthenticated() && isHouseholdMember(resource.data.householdId);
      allow create: if isAuthenticated() && isHouseholdMember(request.resource.data.householdId);
    }

    match /expenses/{expenseId} {
      allow read, update, delete: if isAuthenticated() && isHouseholdMember(resource.data.householdId);
      allow create: if isAuthenticated() && isHouseholdMember(request.resource.data.householdId);
    }

    match /budgets/{budgetId} {
      allow read: if isAuthenticated() && isHouseholdMember(resource.data.householdId);
      allow create, update: if isAuthenticated() && isHouseholdAdmin(request.resource.data.householdId);
      allow delete: if isAuthenticated() && isHouseholdAdmin(resource.data.householdId);
    }

    match /notifications/{notificationId} {
      allow read, update, delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
    }
    
    match /activities/{activityId} {
      allow read: if isAuthenticated() &&
        ((resource.data.keys().hasAll(['householdId']) && isHouseholdMember(resource.data.householdId)) ||
         (resource.data.keys().hasAll(['businessId']) && isBusinessMember(resource.data.businessId)));
      // Members may append activity entries; logs are immutable once written.
      allow create: if isAuthenticated() &&
        request.resource.data.userId == request.auth.uid &&
        ((request.resource.data.keys().hasAll(['householdId']) && isHouseholdMember(request.resource.data.householdId)) ||
         (request.resource.data.keys().hasAll(['businessId']) && isBusinessMember(request.resource.data.businessId)));
      allow update, delete: if false;
    }
    
    // ============================================================================
    // DENY ALL OTHER COLLECTIONS
    // ============================================================================
    
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
