# ============================================================================
# PantryPlus — Environment Variables (Module 12)
# Copy this file to ".env.local" and fill in your own values.
# .env.local is gitignored and must NEVER be committed.
# ============================================================================

# --- Firebase (client SDK) --------------------------------------------------
# From Firebase Console → Project Settings → Your apps → SDK setup & config.
# These are NEXT_PUBLIC_ (exposed to the browser) — this is expected for the
# Firebase web SDK; access is protected by Firestore Security Rules, not secrecy.
NEXT_PUBLIC_FIREBASE_API_KEY=your_api_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id

# --- Google Gemini (server-side AI features) --------------------------------
# Used by the @ai-sdk/google provider for AI chat, recipes, insights, and the
# meal-plan shopping-list generator. Get a key at https://aistudio.google.com/.
# NOT NEXT_PUBLIC_ — keep this secret; it is only read in server route handlers.
GOOGLE_GENERATIVE_AI_API_KEY=your_gemini_api_key_here

# --- Spoonacular (optional recipe API) --------------------------------------
NEXT_PUBLIC_SPOONACULAR_API_KEY=your_spoonacular_key_here
